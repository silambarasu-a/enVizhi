# ─── Postgres (Neon recommended) ────────────────────────────────────────────
# Pooled connection string — used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct connection string — used by `prisma migrate` (no pooler).
DIRECT_DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ─── NextAuth (Auth.js v5) ──────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
AUTH_SECRET="your-32-byte-random-secret-here"
# Public URL of the app. Required in production; optional in dev.
AUTH_URL="http://localhost:3005"

# ─── SMTP (magic links & alerts) ────────────────────────────────────────────
# Works with any SMTP server. All four vars are OPTIONAL in dev — leave them
# blank and magic links print to the terminal instead of sending email.
#
# For Gmail:
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      ("Mail" → "Other (Custom name)" → "Pangu") — copy the 16-char password.
#   3. Use the values below.
#   Limit: ~500 emails/day (personal) or ~2000/day (Workspace).
#
# For Gmail Workspace / Fastmail / other providers, just swap the host.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.address@gmail.com"
SMTP_PASS="your-16-char-app-password"
# Optional override; defaults to "Pangu <SMTP_USER>".
MAIL_FROM=""

# ─── Google OAuth (optional) ────────────────────────────────────────────────
# Leave both blank to hide the "Continue with Google" button. To enable:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (type: Web application)
#   3. Add `http://localhost:3005/api/auth/callback/google` to "Authorized
#      redirect URIs" (and the production equivalent when you deploy)
#   4. Copy the client ID + secret here.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Alert evaluator (cron) ────────────────────────────────────────────────
# Required to call POST /api/alerts/evaluate. Generate with `openssl rand -hex 32`.
# Send via `Authorization: Bearer <secret>` from your cron caller (Vercel Cron,
# GitHub Actions, Inngest, etc.). Leave empty in dev — `npm run check:alerts`
# bypasses the endpoint and runs the same pipeline locally.
CRON_SECRET=""
